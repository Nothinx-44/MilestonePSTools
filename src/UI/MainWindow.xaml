<Window xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Milestone Toolkit"
        Width="1100" Height="700"
        MinWidth="900" MinHeight="500"
        WindowStartupLocation="CenterScreen"
        Background="#1E1E2E">

    <Window.Resources>

        <Style x:Key="ActionButton" TargetType="Button">
            <Setter Property="Background" Value="#313244"/>
            <Setter Property="Foreground" Value="#CDD6F4"/>
            <Setter Property="FontFamily" Value="Segoe UI"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="Padding" Value="16,12"/>
            <Setter Property="Margin" Value="8,3"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="HorizontalContentAlignment" Value="Left"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="border"
                                Background="{TemplateBinding Background}"
                                CornerRadius="6"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter
                                HorizontalAlignment="{TemplateBinding HorizontalContentAlignment}"
                                VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="border" Property="Background" Value="#45475A"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="border" Property="Background" Value="#585B70"/>
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter Property="Opacity" Value="0.4"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="ClearButton" TargetType="Button">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Foreground" Value="#6C7086"/>
            <Setter Property="FontFamily" Value="Segoe UI"/>
            <Setter Property="FontSize" Value="11"/>
            <Setter Property="Padding" Value="10,4"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="BorderBrush" Value="#45475A"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="border"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="4"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="border" Property="Background" Value="#313244"/>
                                <Setter Property="Foreground" Value="#CDD6F4"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="CancelButton" TargetType="Button">
            <Setter Property="Background" Value="#F38BA8"/>
            <Setter Property="Foreground" Value="#1E1E2E"/>
            <Setter Property="FontFamily" Value="Segoe UI"/>
            <Setter Property="FontSize" Value="11"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Padding" Value="12,4"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="border"
                                Background="{TemplateBinding Background}"
                                CornerRadius="4"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="border" Property="Background" Value="#EBA0B5"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="border" Property="Background" Value="#D97090"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="SmallButton" TargetType="Button">
            <Setter Property="Background" Value="#313244"/>
            <Setter Property="Foreground" Value="#A6ADC8"/>
            <Setter Property="FontFamily" Value="Segoe UI"/>
            <Setter Property="FontSize" Value="11"/>
            <Setter Property="Padding" Value="8,4"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="border"
                                Background="{TemplateBinding Background}"
                                CornerRadius="4"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="border" Property="Background" Value="#45475A"/>
                                <Setter Property="Foreground" Value="#CDD6F4"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

    </Window.Resources>

    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="300"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <!-- ============ SIDEBAR ============ -->
        <Border Grid.Column="0" Background="#181825">
            <DockPanel>

                <!-- En-tete -->
                <Border DockPanel.Dock="Top" Padding="20,20,20,12">
                    <StackPanel>
                        <TextBlock Text="Milestone Toolkit"
                                   FontFamily="Segoe UI" FontSize="20" FontWeight="Bold"
                                   Foreground="#CDD6F4"/>
                        <StackPanel Orientation="Horizontal" Margin="0,8,0,0">
                            <Ellipse x:Name="StatusIndicator"
                                     Width="8" Height="8"
                                     Fill="#F38BA8"
                                     Margin="0,0,8,0"
                                     VerticalAlignment="Center"/>
                            <TextBlock x:Name="StatusText"
                                       Text="Non connecte"
                                       FontFamily="Segoe UI" FontSize="12"
                                       Foreground="#A6ADC8" VerticalAlignment="Center"/>
                        </StackPanel>
                    </StackPanel>
                </Border>

                <!-- Separateur -->
                <Border DockPanel.Dock="Top" Height="1" Background="#313244" Margin="16,0"/>

                <!-- Pied de page avec dossier de sortie -->
                <Border DockPanel.Dock="Bottom" Padding="16,12">
                    <StackPanel>
                        <TextBlock Text="DOSSIER DE SORTIE"
                                   FontFamily="Segoe UI" FontSize="10" FontWeight="SemiBold"
                                   Foreground="#585B70" Margin="0,0,0,6"/>
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock x:Name="OutputDirText"
                                       Grid.Column="0"
                                       Text="./Output"
                                       FontFamily="Segoe UI" FontSize="10"
                                       Foreground="#6C7086"
                                       TextTrimming="CharacterEllipsis"
                                       VerticalAlignment="Center"/>
                            <Button x:Name="BtnOutputDir"
                                    Grid.Column="1"
                                    Content="Changer"
                                    Style="{StaticResource SmallButton}"
                                    Margin="8,0,0,0"/>
                        </Grid>
                        <TextBlock Text="v3.0 — Fork by Vincent"
                                   FontFamily="Segoe UI" FontSize="10"
                                   Foreground="#45475A"
                                   HorizontalAlignment="Center"
                                   Margin="0,10,0,0"/>
                    </StackPanel>
                </Border>

                <!-- Boutons d'action -->
                <ScrollViewer VerticalScrollBarVisibility="Auto" Margin="0,8,0,0">
                    <StackPanel>

                        <!-- Categorie : Snapshots -->
                        <TextBlock Text="SNAPSHOTS"
                                   FontFamily="Segoe UI" FontSize="11" FontWeight="SemiBold"
                                   Foreground="#89B4FA" Margin="20,12,0,4"/>

                        <Button x:Name="BtnSnapshotSelected"
                                Style="{StaticResource ActionButton}">
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Text="&#x25B8;" Foreground="#89B4FA" Margin="0,0,10,0" VerticalAlignment="Center"/>
                                <TextBlock Text="Snapshot - Selection"/>
                            </StackPanel>
                        </Button>

                        <Button x:Name="BtnSnapshotAll"
                                Style="{StaticResource ActionButton}">
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Text="&#x25B8;" Foreground="#89B4FA" Margin="0,0,10,0" VerticalAlignment="Center"/>
                                <TextBlock Text="Snapshot - Toutes les cameras"/>
                            </StackPanel>
                        </Button>

                        <Button x:Name="BtnPtzSnapshot"
                                Style="{StaticResource ActionButton}">
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Text="&#x25B8;" Foreground="#89B4FA" Margin="0,0,10,0" VerticalAlignment="Center"/>
                                <TextBlock Text="Snapshot - Presets PTZ"/>
                            </StackPanel>
                        </Button>

                        <!-- Categorie : Gestion -->
                        <TextBlock Text="GESTION"
                                   FontFamily="Segoe UI" FontSize="11" FontWeight="SemiBold"
                                   Foreground="#A6E3A1" Margin="20,20,0,4"/>

                        <Button x:Name="BtnExportHardware"
                                Style="{StaticResource ActionButton}">
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Text="&#x25B8;" Foreground="#A6E3A1" Margin="0,0,10,0" VerticalAlignment="Center"/>
                                <TextBlock Text="Export Hardware (CSV)"/>
                            </StackPanel>
                        </Button>

                        <Button x:Name="BtnGroupByModel"
                                Style="{StaticResource ActionButton}">
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Text="&#x25B8;" Foreground="#A6E3A1" Margin="0,0,10,0" VerticalAlignment="Center"/>
                                <TextBlock Text="Grouper par Modele"/>
                            </StackPanel>
                        </Button>

                    </StackPanel>
                </ScrollViewer>

            </DockPanel>
        </Border>

        <!-- ============ CONTENU PRINCIPAL ============ -->
        <Grid Grid.Column="1">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <!-- En-tete du contenu -->
            <Border Grid.Row="0" Padding="20,16">
                <DockPanel>
                    <Button x:Name="BtnClearLog"
                            DockPanel.Dock="Right"
                            Content="Effacer"
                            Style="{StaticResource ClearButton}"/>
                    <Button x:Name="BtnCancel"
                            DockPanel.Dock="Right"
                            Content="Annuler"
                            Style="{StaticResource CancelButton}"
                            Visibility="Collapsed"
                            Margin="0,0,8,0"/>
                    <TextBlock Text="Journal d'activite"
                               FontFamily="Segoe UI" FontSize="16" FontWeight="SemiBold"
                               Foreground="#CDD6F4" VerticalAlignment="Center"/>
                </DockPanel>
            </Border>

            <!-- Zone de log (RichTextBox pour couleurs) -->
            <Border Grid.Row="1" Margin="20,0,20,12" CornerRadius="8" Background="#11111B">
                <RichTextBox x:Name="LogOutput"
                             IsReadOnly="True"
                             Background="Transparent"
                             Foreground="#CDD6F4"
                             CaretBrush="Transparent"
                             FontFamily="Cascadia Code,Consolas,Courier New"
                             FontSize="12"
                             BorderThickness="0"
                             VerticalScrollBarVisibility="Auto"/>
            </Border>

            <!-- Barre de statut -->
            <Border Grid.Row="2" Background="#181825" Padding="16,10">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>

                    <TextBlock x:Name="ActionStatus"
                               Text="Pret"
                               FontFamily="Segoe UI" FontSize="12"
                               Foreground="#A6ADC8" VerticalAlignment="Center"/>

                    <ProgressBar x:Name="ProgressBar"
                                 Grid.Column="1"
                                 Width="200" Height="4"
                                 Minimum="0" Maximum="100" Value="0"
                                 IsIndeterminate="False"
                                 Background="#313244"
                                 Foreground="#89B4FA"
                                 BorderThickness="0"
                                 Visibility="Collapsed"/>
                </Grid>
            </Border>
        </Grid>

    </Grid>
</Window>
